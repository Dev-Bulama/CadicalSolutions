generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}



model User {
  id            String    @id @default(cuid()) @map("_id")
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  premium       Boolean   @default(false)
  role          String?
  bio           String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  country   String?
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    Int? /// Unix timestamp for ban expiration
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions           Session[]
  accounts           Account[]
  clinician          Clinician[]
  orders             Order[]
  cartItems          CartItem[]
  supplier           Supplier[]
  rfqs               RFQ[]
  bulkOrders         BulkOrder[]
  serviceBookings    ServiceBooking[]
  technicianProfile  TechnicianProfile?
  maintenanceSchedules MaintenanceSchedule[]
  equipmentRecords   EquipmentRecord[]
  serviceContracts   ServiceContract[]
  notifications      Notification[]
}

model Session {
  id             String   @id @default(cuid()) @map("_id")
  userId         String
  token          String
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid()) @map("_id")
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model Clinician {
  id            String   @id @default(cuid())
  userId        String
  firstName     String
  lastName      String
  specialization String
  licenseNumber String?   @unique
  yearsOfExperience Int
  bio           String?
  profileImage  String?
  verified      Boolean  @default(false)
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("clinician")
}




model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  category    ServiceCategory
  icon        String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("service")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  price       Float
  stock       Int
  sku         String   @unique
  image       String?
  specs       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  totalAmount    Float
  status         OrderStatus @default(PENDING)
  paymentId      String?
  paymentMethod  String?
  shippingAddress String?
  notes          String?

  trackingCode     String       @unique
  trackingNumber   String?
  carrier          String?



  trackingEvents  TrackingEvent[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
}



model TrackingEvent {
  id          String   @id @default(cuid())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status      String
  message     String
  location    String?

  createdAt   DateTime @default(now())
}


model Booking {
  id            String   @id @default(cuid())

  service       String

  equipmentType String?
  issueType     String?
  urgency       String?

  consultType   String?
  format        String?

  callerType    String

  firstName     String
  lastName      String
  orgName       String?
  role          String?

  phone         String
  email         String
  location      String

  bookingType   String

  prefDate      String?
  selectedSlot  String?

  callbackDate  String?
  callWindow    String?
  callbackPhone String?

  notes         String?

  ref           String   @unique
  createdAt     DateTime @default(now())
}

model Institution {
  id              String   @id @default(cuid())

  // Institution Profile
  instName        String
  instType        String
  cac             String
  yearEstablished Int?
  staffCount      Int?
  bedCapacity     Int?

  // Location & Contact
  state           String
  lga             String
  address         String
  contactName     String
  designation     String
  phone           String
  altPhone        String?
  email           String

  // Services (store as arrays for simplicity)
  services        String[]
  specialistOpts  String[]
  consultOpts     String[]
  reagentOpts     String[]
  eduOpts         String[]

  volume          String?
  notes           String?

  // Compliance
  nafdac          String?
  pcn             String?
  confirmDocs     Boolean @default(false)

  // Account
  accountEmail    String   @unique
  passwordHash    String

  // Relations
  documents             Document[]
  rfqs                  RFQ[]
  bulkOrders            BulkOrder[]
  maintenanceSchedules  MaintenanceSchedule[]
  equipmentRecords      EquipmentRecord[]
  serviceContracts      ServiceContract[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Document {
  id            String   @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id])

  name          String
  type          String // CAC, NAFDAC, OTHER
  url           String

  status        String @default("Pending")

  createdAt     DateTime @default(now())
}

model Referral {
  id                    String    @id @default(cuid())
  refId                 String    @unique
  
  // Referrer Details
  referrerFullName      String
  referrerDesignation   String
  referrerFacility      String
  referrerFacilityType  String
  referrerPhone         String
  referrerEmail         String?
  referrerState         String
  referrerLGA           String?
  referrerAddress       String?
  
  // Client Details
  clientFacilityName    String
  clientType            String
  clientContactPerson   String?
  clientPhone           String
  clientEmail           String?
  clientState           String
  clientLGA             String?
  clientAddress         String?
  
  // Supply Details
  reasonForRequest      String
  supplyCategory        String[]  @default([])
  specificTests         String[]  @default([])
  urgencyLevel          String
  quantity              String?
  deliveryMethod        String?
  additionalNotes       String?
  
  // Additional Details
  affiliateId           String?
  referredVia           String?
  paymentPreference     String?
  estimatedValue        String?
  consent               Boolean   @default(false)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}


enum ServiceCategory {
  CONSULTATIONS
  PHARMACEUTICALS
  SURGICAL_EQUIPMENT
  DIAGNOSTICS
  REHABILITATION
  EMERGENCY
  COSMETICS
  REFERRALS
}




enum Role {
  SUPER_ADMIN
  CLINICIAN
}

enum ProductCategory {
  EQUIPMENT
  CONSUMABLES
  PHARMACEUTICALS
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─────────────────────────────────────────────
// CRM INTEGRATION ENGINE
// ─────────────────────────────────────────────

model CrmConnection {
  id              String   @id @default(cuid())
  provider        String   // zoho | hubspot | salesforce | freshsales | custom
  isActive        Boolean  @default(false)
  isConnected     Boolean  @default(false)

  // OAuth / API credentials (encrypted at app layer)
  clientId        String?
  clientSecret    String?
  redirectUri     String?
  accessToken     String?  @db.Text
  refreshToken    String?  @db.Text
  tokenExpiresAt  DateTime?
  organizationId  String?
  apiDomain       String?  // Zoho data center domain

  // Sync config
  syncEnabled     Boolean  @default(false)
  syncInterval    String   @default("hourly") // 5min | 15min | hourly | daily
  lastSyncAt      DateTime?
  nextSyncAt      DateTime?

  // Health
  healthScore     Int      @default(100)
  lastError       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fieldMappings   CrmFieldMapping[]
  syncLogs        CrmSyncLog[]
  automationRules CrmAutomationRule[]
  webhookLogs     CrmWebhookLog[]
  failedJobs      CrmFailedJob[]

  @@map("crm_connection")
}

model CrmFieldMapping {
  id              String   @id @default(cuid())
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  entity          String   // contact | account | deal | lead | ticket
  cadicalField    String
  crmField        String
  direction       String   @default("both") // tocrm | fromcrm | both
  isRequired      Boolean  @default(false)
  transformFn     String?  // optional JS transform expression

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([connectionId, entity, cadicalField])
  @@map("crm_field_mapping")
}

model CrmSyncLog {
  id              String   @id @default(cuid())
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  syncType        String   // instant | scheduled | manual
  entity          String   // contact | account | deal | lead
  direction       String   // push | pull
  status          String   // running | success | partial | failed
  recordsTotal    Int      @default(0)
  recordsSynced   Int      @default(0)
  recordsFailed   Int      @default(0)
  errorSummary    String?
  durationMs      Int?

  startedAt       DateTime @default(now())
  completedAt     DateTime?

  @@map("crm_sync_log")
}

model CrmAutomationRule {
  id              String   @id @default(cuid())
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  isActive        Boolean  @default(true)

  triggerEvent    String   // order_completed | rfq_submitted | booking_created | user_inactive
  triggerConfig   Json?    // e.g. { "days": 30 } for inactivity

  actionType      String   // create_deal | create_lead | create_contact | create_ticket | update_stage
  actionConfig    Json?    // pipeline, stage, owner, tags, etc.

  lastRunAt       DateTime?
  runCount        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("crm_automation_rule")
}

model CrmWebhookLog {
  id              String   @id @default(cuid())
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  event           String
  payload         Json
  status          String   // received | processed | failed
  errorMessage    String?

  receivedAt      DateTime @default(now())

  @@map("crm_webhook_log")
}

model CrmFailedJob {
  id              String   @id @default(cuid())
  connectionId    String
  connection      CrmConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  entity          String
  operation       String   // create | update | delete
  payload         Json
  errorMessage    String
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  status          String   @default("pending") // pending | retrying | resolved | abandoned

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("crm_failed_job")
}

// ─────────────────────────────────────────────
// SUPPLIER / VENDOR MARKETPLACE
// ─────────────────────────────────────────────

model Supplier {
  id              String   @id @default(cuid())
  userId          String?  // linked to User if they have an account
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  companyName     String
  contactName     String
  email           String   @unique
  phone           String
  altPhone        String?
  website         String?

  category        String[] // medical_equipment | consumables | pharmaceuticals | etc.
  description     String?
  logo            String?

  // Address
  address         String
  city            String
  state           String
  country         String   @default("Nigeria")

  // Business info
  cacNumber       String?
  taxId           String?
  nafdacNumber    String?
  yearEstablished Int?

  // Status
  status          SupplierStatus @default(PENDING)
  isActive        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedBy      String?  // admin user id

  // Performance
  totalProducts   Int      @default(0)
  totalOrders     Int      @default(0)
  rating          Float    @default(0)
  deliveryScore   Float    @default(0)

  documents       SupplierDocument[]
  products        SupplierProduct[]
  rfqBids         RFQBid[]
  bulkOrders      BulkOrder[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("supplier")
}

model SupplierDocument {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  name        String
  type        String   // CAC | NAFDAC | TAX | LICENSE | OTHER
  url         String
  status      String   @default("pending") // pending | approved | rejected
  reviewNote  String?

  uploadedAt  DateTime @default(now())
  reviewedAt  DateTime?

  @@map("supplier_document")
}

model SupplierProduct {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  name            String
  description     String
  category        String
  brand           String?
  model           String?
  sku             String?

  unitPrice       Float
  bulkPrice       Float?
  minOrderQty     Int      @default(1)
  stock           Int      @default(0)

  images          String[]
  specs           Json?
  certifications  String[]
  manualUrl       String?  // PDF manual
  datasheetUrl    String?

  hasInstallation Boolean  @default(false)
  hasWarranty     Boolean  @default(false)
  warrantyMonths  Int?
  hasMaintenance  Boolean  @default(false)

  isActive        Boolean  @default(true)
  isApproved      Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("supplier_product")
}

model RFQ {
  id              String   @id @default(cuid())
  rfqCode         String   @unique

  // Requester info
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  institutionId   String?
  institution     Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  contactName     String
  contactEmail    String
  contactPhone    String
  organization    String?

  // Request details
  title           String
  description     String
  category        String[]
  specifications  String?
  quantity        Int
  targetBudget    Float?
  currency        String   @default("NGN")
  deliveryDate    DateTime?
  deliveryAddress String?

  // Attachments
  attachments     String[]

  status          RFQStatus @default(OPEN)
  closingDate     DateTime?

  bids            RFQBid[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("rfq")
}

model RFQBid {
  id          String   @id @default(cuid())
  rfqId       String
  rfq         RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  unitPrice   Float
  totalPrice  Float
  leadTimeDays Int
  notes       String?
  attachments String[]

  status      String   @default("submitted") // submitted | shortlisted | accepted | rejected

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([rfqId, supplierId])
  @@map("rfq_bid")
}

model BulkOrder {
  id              String   @id @default(cuid())
  bulkCode        String   @unique

  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  institutionId   String?
  institution     Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  supplierId      String?
  supplier        Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  contactName     String
  contactEmail    String
  contactPhone    String
  organization    String?

  items           Json     // [{ productName, sku, quantity, unitPrice }]
  totalAmount     Float
  currency        String   @default("NGN")
  discountPercent Float    @default(0)
  finalAmount     Float

  deliveryAddress String?
  deliveryDate    DateTime?
  paymentTerms    String?
  contractUrl     String?

  status          BulkOrderStatus @default(DRAFT)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("bulk_order")
}

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum RFQStatus {
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum BulkOrderStatus {
  DRAFT
  SUBMITTED
  NEGOTIATING
  APPROVED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─────────────────────────────────────────────
// SERVICE BOOKING + TECHNICIAN ECOSYSTEM
// ─────────────────────────────────────────────

model ServiceBooking {
  id               String   @id @default(cuid())
  bookingCode      String   @unique

  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Equipment info
  equipmentName    String
  equipmentModel   String?
  equipmentSerial  String?
  equipmentBrand   String?

  // Service details
  serviceType      ServiceType
  urgency          ServiceUrgency @default(NORMAL)
  issueDescription String
  severity         String?        // low | medium | high | critical
  equipmentCondition String?

  // Site info
  siteAddress      String
  siteCity         String
  siteState        String
  siteContact      String?
  sitePhone        String?

  // Dynamic fields (JSON for service-type-specific data)
  dynamicFields    Json?

  // Schedule
  preferredDate    DateTime?
  preferredTimeSlot String?
  alternateDate    DateTime?

  // Media
  images           String[]
  documents        String[]

  // Payment
  estimatedCost    Float?
  finalCost        Float?
  paymentStatus    String    @default("unpaid")
  paymentId        String?

  // Fulfillment
  status           ServiceStatus @default(BOOKED)
  assignedTechId   String?
  assignedTech     TechnicianProfile? @relation(fields: [assignedTechId], references: [id], onDelete: SetNull)

  statusEvents     ServiceStatusEvent[]
  serviceJob       ServiceJob?
  equipmentRecord  EquipmentRecord?

  notes            String?
  adminNotes       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("service_booking")
}

model ServiceStatusEvent {
  id            String   @id @default(cuid())
  bookingId     String
  booking       ServiceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  status        ServiceStatus
  message       String
  notes         String?
  location      String?
  updatedBy     String?  // userId or technicianId
  updatedByRole String?  // admin | technician | system

  createdAt     DateTime @default(now())

  @@map("service_status_event")
}

model TechnicianProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName        String
  lastName         String
  phone            String
  profileImage     String?

  specializations  String[]  // installation | repair | calibration | etc.
  certifications   String[]
  yearsOfExperience Int      @default(0)

  // Location
  state            String
  city             String
  baseAddress      String?

  // Availability
  isAvailable      Boolean  @default(true)
  isOnJob          Boolean  @default(false)
  currentLocation  String?  // JSON {lat, lng} — optional live location
  shareLocation    Boolean  @default(false)

  // Status
  status           TechStatus @default(ACTIVE)
  rating           Float    @default(0)
  totalJobs        Int      @default(0)
  completedJobs    Int      @default(0)

  serviceBookings  ServiceBooking[]
  serviceJobs      ServiceJob[]
  maintenanceAssignments MaintenanceSchedule[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("technician_profile")
}

model ServiceJob {
  id               String   @id @default(cuid())
  jobCode          String   @unique
  bookingId        String   @unique
  booking          ServiceBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  technicianId     String?
  technician       TechnicianProfile? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  status           JobStatus @default(ASSIGNED)

  // Technician inputs
  diagnosticNotes  String?
  workDone         String?
  partsUsed        Json?    // [{name, qty, cost}]
  partsRequested   Json?
  reportUrl        String?
  completionImages String[]

  // Timing
  scheduledAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  estimatedDuration Int?    // minutes

  // Billing
  laborCost        Float?
  partsCost        Float?
  totalCost        Float?
  invoiceUrl       String?

  followUpDate     DateTime?
  followUpNotes    String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("service_job")
}

model MaintenanceSchedule {
  id               String   @id @default(cuid())
  scheduleCode     String   @unique

  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  institutionId    String?
  institution      Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  technicianId     String?
  technician       TechnicianProfile? @relation(fields: [technicianId], references: [id], onDelete: SetNull)

  equipmentName    String
  equipmentModel   String?
  equipmentSerial  String?
  serviceType      ServiceType
  frequency        MaintenanceFrequency
  siteAddress      String
  siteState        String

  nextDueDate      DateTime
  lastCompletedAt  DateTime?
  isActive         Boolean  @default(true)

  reminderDaysBefore Int    @default(7)
  autoAssign       Boolean  @default(false)

  notes            String?
  contractId       String?

  history          MaintenanceLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("maintenance_schedule")
}

model MaintenanceLog {
  id             String   @id @default(cuid())
  scheduleId     String
  schedule       MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  completedAt    DateTime
  technicianId   String?
  notes          String?
  reportUrl      String?
  partsUsed      Json?
  cost           Float?

  createdAt      DateTime @default(now())

  @@map("maintenance_log")
}

model EquipmentRecord {
  id               String   @id @default(cuid())
  passportCode     String   @unique

  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  institutionId    String?
  institution      Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  bookingId        String?  @unique
  booking          ServiceBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Equipment identity
  equipmentName    String
  brand            String?
  model            String?
  serialNumber     String?
  purchaseDate     DateTime?
  warrantyExpiry   DateTime?
  purchasePrice    Float?

  // Health
  condition        String   @default("good") // excellent | good | fair | poor
  lastInspectedAt  DateTime?
  nextMaintenanceAt DateTime?

  serviceHistory   Json?    // array of service events
  notes            String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("equipment_record")
}

model ServiceContract {
  id               String   @id @default(cuid())
  contractCode     String   @unique

  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  institutionId    String?
  institution      Institution? @relation(fields: [institutionId], references: [id], onDelete: SetNull)

  plan             ContractPlan
  status           ContractStatus @default(ACTIVE)

  startDate        DateTime
  endDate          DateTime
  renewalDate      DateTime?

  // SLA
  responseHours    Int      @default(24)
  resolutionHours  Int      @default(72)
  includedVisits   Int      @default(4)
  usedVisits       Int      @default(0)
  emergencySupport Boolean  @default(false)
  dedicatedTechId  String?

  monthlyFee       Float?
  annualFee        Float?
  currency         String   @default("NGN")

  equipmentList    Json?    // covered equipment
  terms            String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("service_contract")
}

// ─────────────────────────────────────────────
// INTERNAL CHAT SYSTEM
// ─────────────────────────────────────────────

model ChatRoom {
  id           String   @id @default(cuid())
  type         String   // support | technician | supplier | procurement
  reference    String?  // bookingId / orderId / rfqId
  participants String[] // userIds
  isActive     Boolean  @default(true)

  messages     ChatMessage[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("chat_room")
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  senderId   String
  senderRole String   // admin | technician | customer | supplier
  senderName String
  content    String
  attachments String[]
  isRead     Boolean  @default(false)
  readAt     DateTime?

  createdAt  DateTime @default(now())

  @@map("chat_message")
}

// ─────────────────────────────────────────────
// NOTIFICATION CENTER
// ─────────────────────────────────────────────

model Notification {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String   // order | service | payment | maintenance | system | crm
  title      String
  message    String
  actionUrl  String?
  isRead     Boolean  @default(false)
  readAt     DateTime?

  // Delivery channels
  sentEmail  Boolean  @default(false)
  sentSMS    Boolean  @default(false)
  sentPush   Boolean  @default(false)

  createdAt  DateTime @default(now())

  @@map("notification")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  userRole   String?

  action     String   // create | update | delete | login | approve | reject | sync
  entity     String   // user | product | order | supplier | booking | crm
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@map("audit_log")
}

