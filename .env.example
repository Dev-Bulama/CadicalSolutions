# ─────────────────────────────────────────────────────────────────────────────
# CADICAL SOLUTIONS — Environment Variables
# Copy this file to .env.local and fill in real values
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/cadical?sslmode=require

# Prisma Accelerate (optional — for connection pooling)
PRISMA_ACCELERATE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY

# ── Authentication (better-auth) ──────────────────────────────────────────────
BETTER_AUTH_SECRET=your-32-char-or-longer-secret-key
BETTER_AUTH_URL=https://yourdomain.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cadical.com
SMTP_PASS=your-smtp-app-password
EMAIL_FROM=Cadical Solutions <noreply@cadical.com>

# ── Cloudinary (media storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Flutterwave (payments) ────────────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X

# ── Pusher (real-time / WebSockets) ──────────────────────────────────────────
PUSHER_APP_ID=1234567
PUSHER_KEY=abcdef1234567890
PUSHER_SECRET=your-pusher-secret
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=abcdef1234567890
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ── Zoho CRM ──────────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Accounts domain: accounts.zoho.com | accounts.zoho.eu | accounts.zoho.in
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
# Your Cadical callback URL registered in Zoho
ZOHO_REDIRECT_URI=https://yourdomain.com/api/admin/crm/zoho/callback

# ── AfterShip (order tracking) ────────────────────────────────────────────────
AFTERSHIP_API_KEY=asat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AFTERSHIP_WEBHOOK_SECRET=your-aftership-webhook-secret

# ── WhatsApp (notifications) ──────────────────────────────────────────────────
# Meta WhatsApp Business API
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789012345
NEXT_PUBLIC_WHATSAPP_NUMBER=+2348012345678

# ── Web Push Notifications ────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA

# ── Security ──────────────────────────────────────────────────────────────────
# JWT for mobile API authentication
JWT_SECRET=your-64-char-jwt-secret-key-change-this-in-production
# Rate limiting window in ms (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP
RATE_LIMIT_MAX=100

# ── Feature Flags ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENABLE_PUSHER=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# ── Sentry (error monitoring — optional) ─────────────────────────────────────
# SENTRY_DSN=https://xxxxxx@o0.ingest.sentry.io/xxxxxxx
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxx@o0.ingest.sentry.io/xxxxxxx
